PORT=3001
NODE_ENV=production

# Your Supabase project (already have these)
SUPABASE_URL=https://bzmyhlkwssyhxkqrjmwj.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret — use any long random string
JWT_SECRET=invoicepro-super-secret-key-change-this-2024

# Stripe — switch to LIVE keys when ready
STRIPE_SECRET_KEY=sk_live_your-live-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_live_your-live-key

# Gmail SMTP (already working)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=parekhankit3@gmail.com
SMTP_PASS=your-16-char-gmail-app-password
EMAIL_FROM=InvoicePro <parekhankit3@gmail.com>

# Anthropic AI (for AI assistant feature)
ANTHROPIC_API_KEY=sk-ant-your-key

# Twilio (for WhatsApp/SMS — optional)
TWILIO_ACCOUNT_SID=your-sid
TWILIO_AUTH_TOKEN=your-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=your-number

# These get set AFTER Vercel deploys frontend
FRONTEND_URL=https://your-app.vercel.app
APP_URL=https://your-backend.railway.app
